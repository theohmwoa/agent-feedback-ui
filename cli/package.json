{
  "name": "agent-ui",
  "version": "0.1.0",
  "description": "CLI for the agent-ui component catalog. Copies React components for AI agent action surfaces into your project.",
  "type": "module",
  "bin": {
    "agent-ui": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": ["agent-ui", "ai-agents", "components", "react", "tsx", "cli"],
  "homepage": "https://theohmwoa.github.io/agent-feedback-ui/",
  "repository": {
    "type": "git",
    "url": "https://github.com/theohmwoa/agent-feedback-ui.git",
    "directory": "cli"
  },
  "license": "MIT",
  "dependencies": {
    "kleur": "^4.1.5",
    "prompts": "^2.4.2"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "@types/prompts": "^2.4.9",
    "tsup": "^8.3.5",
    "typescript": "^5.6.3"
  }
}
