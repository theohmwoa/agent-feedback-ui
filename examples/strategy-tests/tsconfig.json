{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "lib": ["ES2022"],
    "paths": {
      "agent-feedback-ui": ["../../src/index.ts"],
      "agent-feedback-ui/*": ["../../src/*"]
    }
  },
  "include": ["./*.ts"]
}
